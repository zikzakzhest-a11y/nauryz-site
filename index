/* Footer */
footer { text-align:center; padding:40px 20px; background:#040a18; border-top: 1px solid rgba(255,215,0,0.1); }

/* Animations */
.animate { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
.animate.show { opacity: 1; transform: translateY(0); }

/* Responsive Table */
@media(max-width:768px){
