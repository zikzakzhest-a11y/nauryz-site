.hero-subtitle { font-size: 1.5rem; font-weight: 300; letter-spacing: 3px; margin-bottom: 20px; }
.hero-date { background: rgba(255, 215, 0, 0.1); padding: 10px 25px; border-radius: 50px; border: 1px solid rgba(255,215,0,0.3); display: inline-block; margin-top: 20px;}

.hero-btns { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; margin-top: 40px; }

.btn { 
    padding:15px 40px; 
    border:2px solid #FFD700; color:#FFD700; 
    font-weight:bold; border-radius:50px; 
    text-transform: uppercase; letter-spacing: 1px;
    transition: all 0.3s ease; 
    background: transparent;
}
.btn:hover { background:#FFD700; color:#0a1a2f; cursor:pointer; transform: scale(1.05); box-shadow: 0 0 20px rgba(255,215,0,0.4); }

.btn-reg {
    background: #FFD700; color: #0a1a2f;
}
.btn-reg:hover { background: #fff; border-color: #fff; }

/* SVG Оюлар */
.ornament { position:absolute; fill:none; stroke:#FFD700; stroke-width: 2; opacity:0.15; animation:float 6s ease-in-out infinite; pointer-events: none;}
@keyframes float {0%,100%{transform:translateY(0) rotate(0deg);}50%{transform:translateY(-20px) rotate(5deg);}}

/* Info Block */
.info { max-width:1200px; margin:0 auto; text-align:center; }
.info-text-box { background: rgba(255,255,255,0.03); padding: 30px; border-radius: 15px; border: 1px solid rgba(255,215,0,0.2); backdrop-filter: blur(10px); text-align: left; max-width: 800px; margin: 0 auto;}

/* Goals */
.goals { display:flex; flex-wrap:wrap; justify-content:center; gap:25px; margin-top:40px; }
.goal-card { 
    background: linear-gradient(145deg, #0a1a2f, #061026); 
    border:1px solid rgba(255,215,0,0.3); border-radius:15px; 
    padding:30px 20px; width:260px; text-align:center; 
    transition: all 0.4s; position: relative; overflow: hidden;
