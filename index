.table-wrapper { overflow-x: auto; background: rgba(6, 16, 38, 0.8); border-radius: 15px; border: 1px solid rgba(255,215,0,0.2); }
.program-table { width:100%; border-collapse:collapse; color:#fff; text-align: left;}
.program-table th { background:rgba(255, 215, 0, 0.1); color: #FFD700; font-weight: 600; text-transform: uppercase; font-size: 0.9rem;}
.program-table th, .program-table td { padding:18px 20px; border-bottom:1px solid rgba(255,215,0,0.1); }
.program-table tr:last-child td { border-bottom: none; }
.program-table tbody tr:hover { background: rgba(255,215,0,0.05); }

