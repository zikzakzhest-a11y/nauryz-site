.goal-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: #FFD700; transform: scaleX(0); transition: 0.4s; }
.goal-card:hover::before { transform: scaleX(1); }
.goal-card:hover { transform:translateY(-10px); box-shadow:0 15px 30px rgba(0,0,0,0.5), 0 0 15px rgba(255,215,0,0.1); border-color: #FFD700; }

